# ── Python cache ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Virtual environments ─────────────────────────────────────────────────────
venv/
env/
.env
.venv/

# ── Development tools ────────────────────────────────────────────────────────
.git/
.gitignore
.DS_Store
*.log

